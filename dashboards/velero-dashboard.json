{
  "title": "Velero — Sauvegardes Kubernetes",
  "uid": "velero-backups",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "1m",
  "time": { "from": "now-24h", "to": "now" },
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "tags": ["velero", "backup"],
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "Stockage S3 (Garage)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "Indisponible", "color": "red" },
                "1": { "text": "Disponible", "color": "green" }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background", "graphMode": "none" },
      "targets": [
        {
          "expr": "velero_backup_location_status_gauge",
          "legendFormat": "{{backup_location_name}}",
          "instant": true
        }
      ]
    },
    {
      "id": 2,
      "title": "Backup daily",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "Echec", "color": "red" },
                "1": { "text": "Succès", "color": "green" }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background", "graphMode": "none" },
      "targets": [
        {
          "expr": "velero_backup_last_status{schedule=\"homepage-velero-homepage-daily\"}",
          "legendFormat": "daily",
          "instant": true
        }
      ]
    },
    {
      "id": 3,
      "title": "Backup horaire",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "Echec", "color": "red" },
                "1": { "text": "Succès", "color": "green" }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background", "graphMode": "none" },
      "targets": [
        {
          "expr": "velero_backup_last_status{schedule=\"homepage-velero-homepage-hourly\"}",
          "legendFormat": "horaire",
          "instant": true
        }
      ]
    },
    {
      "id": 4,
      "title": "Âge dernier backup daily",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "h",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 25 },
              { "color": "red", "value": 49 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background", "graphMode": "none" },
      "targets": [
        {
          "expr": "(time() - velero_backup_last_successful_timestamp{schedule=\"homepage-velero-homepage-daily\"}) / 3600",
          "legendFormat": "",
          "instant": true
        }
      ]
    },
    {
      "id": 5,
      "title": "Âge dernier backup horaire",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "h",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 2 },
              { "color": "red", "value": 4 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background", "graphMode": "none" },
      "targets": [
        {
          "expr": "(time() - velero_backup_last_successful_timestamp{schedule=\"homepage-velero-homepage-hourly\"}) / 3600",
          "legendFormat": "",
          "instant": true
        }
      ]
    },
    {
      "id": 6,
      "title": "Total backups stockés",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background", "graphMode": "none" },
      "targets": [
        {
          "expr": "velero_backup_total",
          "legendFormat": "",
          "instant": true
        }
      ]
    },
    {
      "id": 9,
      "title": "Taille des sauvegardes",
      "type": "bargauge",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 104857600 },
              { "color": "red", "value": 524288000 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true
      },
      "targets": [
        {
          "expr": "velero_backup_tarball_size_bytes",
          "legendFormat": "{{schedule}}",
          "instant": true
        }
      ]
    }
  ]
}
